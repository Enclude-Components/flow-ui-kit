<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Flow Header</masterLabel>
    <description>Displays a styled section header with an optional icon for use on Flow screens.</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property
                name="heading"
                type="String"
                label="Heading"
                description="The header text to display."
                role="inputOnly"
            />
            <property
                name="iconName"
                type="String"
                label="Icon Name"
                description="Optional SLDS icon name to display to the left of the heading (e.g. standard:account, utility:info). Leave blank for no icon."
                role="inputOnly"
            />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>